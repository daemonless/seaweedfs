#!/bin/sh
# Daemonless healthcheck for seaweedfs — role-appropriate.

MODE="${SEAWEEDFS_MODE:-server}"
case "$MODE" in
    master|server|mini) fetch -qo /dev/null "http://127.0.0.1:9333/cluster/healthz" >/dev/null 2>&1 ;;
    volume)             nc -z 127.0.0.1 8080 >/dev/null 2>&1 ;;
    filer)              nc -z 127.0.0.1 8888 >/dev/null 2>&1 ;;
    s3)                 nc -z 127.0.0.1 8333 >/dev/null 2>&1 ;;
    *)                  false ;;
esac
