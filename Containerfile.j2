ARG BASE_VERSION=15
FROM ghcr.io/daemonless/base:${BASE_VERSION}

ARG FREEBSD_ARCH=amd64
ARG UPSTREAM_URL="https://api.github.com/repos/seaweedfs/seaweedfs/releases/latest"
ARG UPSTREAM_JQ=".tag_name"
ARG HEALTHCHECK_ENDPOINT="http://localhost:9333/cluster/healthz"

ENV HEALTHCHECK_URL="${HEALTHCHECK_ENDPOINT}"

LABEL org.opencontainers.image.title="{{ title }}" \
      org.opencontainers.image.description="{{ description }}" \
      org.opencontainers.image.source="{{ repo_url }}" \
      org.opencontainers.image.url="{{ web_url }}" \
      org.opencontainers.image.licenses="Apache-2.0" \
      org.opencontainers.image.vendor="daemonless" \
      org.opencontainers.image.authors="daemonless" \
      io.daemonless.category="{{ category }}" \
      io.daemonless.port="8333" \
      io.daemonless.arch="${FREEBSD_ARCH}" \
      io.daemonless.upstream-url="${UPSTREAM_URL}" \
      io.daemonless.upstream-jq="${UPSTREAM_JQ}" \
      io.daemonless.healthcheck-url="${HEALTHCHECK_ENDPOINT}"

# Download the official FreeBSD `weed` binary for this release
RUN VERSION=$(fetch -qo - "${UPSTREAM_URL}" | jq -r "${UPSTREAM_JQ}") && \
    case "${FREEBSD_ARCH}" in \
      amd64) SWARCH=freebsd_amd64 ;; \
      arm64|aarch64) SWARCH=freebsd_arm64 ;; \
      *) echo "unsupported arch: ${FREEBSD_ARCH}" >&2; exit 1 ;; \
    esac && \
    fetch -qo /tmp/weed.tar.gz \
      "https://github.com/seaweedfs/seaweedfs/releases/download/${VERSION}/${SWARCH}.tar.gz" && \
    tar -xzf /tmp/weed.tar.gz -C /usr/local/bin weed && \
    chmod +x /usr/local/bin/weed && \
    rm /tmp/weed.tar.gz && \
    mkdir -p /app && \
    echo "${VERSION}" > /app/version

# Copy root filesystem
COPY root/ /

RUN chmod +x /etc/services.d/seaweedfs/run /etc/cont-init.d/20-seaweedfs /healthz

EXPOSE 8333 9333 8888 8080
VOLUME ["/config", "/data"]
